{% extends 'base.html.twig' %}

{% block body %}
<style>
.sortable-header {
    cursor: pointer;
    text-decoration: none;
    color: inherit;
}
.sortable-header:hover {
    text-decoration: underline;
}
.sort-icon {
    font-size: 0.8em;
    margin-left: 5px;
    opacity: 0.5;
}
.log-link {
    opacity: 0.6;
    transition: opacity 0.2s;
}
.log-link:hover {
    opacity: 1;
}
</style>
<div class="card shadow rounded mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">🩺 Monitoring & Logs</h5>
        <div>
            <button id="btn-check-selected" class="btn btn-primary btn-sm mr-2" onclick="checkHealth('selected')" title="Vérifier cochés"><i class="fa-solid fa-check-square"></i> Vérifier</button>
            <button id="btn-stop-health" class="btn btn-danger btn-sm d-none" onclick="stopHealthCheck()" title="Arrêter"><i class="fa-solid fa-stop"></i> Arrêter</button>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 text-nowrap" id="projects-table">
                <thead class="thead-dark">
                    <tr>
                        <th class="text-center" style="width: 30px;">
                            <input type="checkbox" id="check-all" title="Tout cocher/décocher">
                        </th>
                        <th style="width: 50px;">#</th>
                        <th><a class="sortable-header" data-sort="sf">SF <i class="fa-solid fa-sort sort-icon"></i></a></th>
                        <th><a class="sortable-header" data-sort="subsf">SUB SF <i class="fa-solid fa-sort sort-icon"></i></a></th>
                        <th><a class="sortable-header" data-sort="name">Nom <i class="fa-solid fa-sort sort-icon"></i></a></th>
                        <th><a class="sortable-header" data-sort="gcp">GCP <i class="fa-solid fa-sort sort-icon"></i></a></th>
                        <th class="text-center" style="width: 120px;">DEV</th>
                        <th class="text-center" style="width: 120px;">RECETTE</th>
                        <th class="text-center" style="width: 120px;">PP</th>
                        <th class="text-center" style="width: 120px;">PROD</th>
                        <th class="text-center" style="width: 80px;">Action</th>
                    </tr>
                    <tr>
                        <th></th>
                        <th></th>
                        <th>
                            <select id="filter_sf" class="form-control form-control-sm filter-input">
                                <option value="all">Tous</option>
    {% for key, value in sfs %}
                                <option value="{{ key }}">{{ value }}</option>
    {% endfor %}
                            </select>
                        </th>
                        <th>
                            <select id="filter_subsf" class="form-control form-control-sm filter-input">
                                <option value="all">Tous</option>
    {% for key, value in subsfs %}
                                <option value="{{ key }}">{{ value }}</option>
    {% endfor %}
                            </select>
                        </th>
                        <th>
                            <input id="filter_project_name" class="form-control form-control-sm filter-input" value="" placeholder="Filtrer..." />
                        </th>
                        <th>
                            <select id="filter_gcp" class="form-control form-control-sm filter-input">
                                <option value="all">Tous</option>
                                <option value="non">Non</option>
                                <option value="oui">Oui</option>
                            </select>
                        </th>
                        <th colspan="5"></th>
                    </tr>
                </thead>
                <tbody id="projects-tbody">
                    {% for r in results %}
                        <tr class="project-row" data-project-name="{{ r.name }}">
                            <td class="text-center">
                                <input type="checkbox" class="row-checkbox">
                            </td>
                            <td class="col-index text-muted font-weight-bold"></td>
                            <td class="col-sf" data-value="{{ r.sf }}">{{ r.sf }}</td>
                            <td class="col-subsf" data-value="{{ r.subsf }}">{{ r.subsf }}</td>
                            <td class="col-name">{{ r.name }}</td>
                            <td class="col-gcp" data-value="{% if r.cloudGCP == 1 %}oui{% else %}non{% endif %}">
                                {% if r.cloudGCP == 1 %}Oui{% else %}Non{% endif %}
                            </td>

                            {% for env in ['dev', 'rec', 'pp', 'prod'] %}
                            <td class="col-{{ env }} text-center" data-env="{{ env }}"
                                data-url-health="{{ r.urlHealthCheck[env] | default('') }}"
                                data-url-logs="{{ r.urlLogs[env] | default('') }}">

                                <span class="health-badge badge badge-secondary"><i class="fa-solid fa-hourglass"></i></span>

                                {% if r.urlLogs[env] is defined and r.urlLogs[env] != '' %}
                                <a href="{{ r.urlLogs[env] }}" class="log-link ml-2" target="_blank" title="Voir les logs de {{ env }}">
                                    <i class="fa-solid fa-file-lines text-info"></i>
                                </a>
                                {% else %}
                                <a href="#" class="log-link ml-2 text-muted" onclick="return false;" title="Logs non disponibles">
                                    <i class="fa-solid fa-file-lines"></i>
                                </a>
                                {% endif %}
                            </td>
                            {% endfor %}

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary btn-check-single" onclick="checkSingleRow(this)"><i class="fa-solid fa-rotate"></i></button>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer d-flex justify-content-between align-items-center">
        <div>
            <select id="rows_per_page" class="form-control form-control-sm d-inline-block w-auto">
                <option value="10">10 par page</option>
                <option value="15" selected>15 par page</option>
                <option value="25">25 par page</option>
                <option value="50">50 par page</option>
                <option value="1000">Tout afficher</option>
            </select>
            <span id="pagination-info" class="ml-2 text-muted small"></span>
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0" id="pagination-container">
                <!-- Les boutons de pagination seront générés ici par JS -->
            </ul>
        </nav>
    </div>
</div>

<script>
// --- LOGIQUE DE FILTRAGE ET PAGINATION ---
let getVisibleRows; // Fonction globale pour accéder aux lignes visibles

document.addEventListener('DOMContentLoaded', function() {
    // Éléments DOM (Filtres)
    const filterSf = document.getElementById('filter_sf');
    const filterSubsf = document.getElementById('filter_subsf');
    const filterProjectName = document.getElementById('filter_project_name');
    const filterGcp = document.getElementById('filter_gcp');
    const tbody = document.getElementById('projects-tbody');
    let rows = Array.from(document.querySelectorAll('.project-row'));

    // Éléments DOM (Pagination)
    const rowsPerPageSelect = document.getElementById('rows_per_page');
    const paginationContainer = document.getElementById('pagination-container');
    const paginationInfo = document.getElementById('pagination-info');

    // Checkbox principale
    const checkAll = document.getElementById('check-all');

    // État de la pagination et du tri
    let currentPage = 1;
    let rowsPerPage = parseInt(rowsPerPageSelect.value);
    let filteredRows = [];
    let displayedRows = []; // Lignes affichées sur la page courante
    let currentSortColumn = '';
    let currentSortDirection = 'asc'; // 'asc' ou 'desc'

    getVisibleRows = () => displayedRows;

    // --- LOGIQUE DE TRI ---
    const sortHeaders = document.querySelectorAll('.sortable-header');

    sortHeaders.forEach(header => {
        header.addEventListener('click', function() {
            const column = this.getAttribute('data-sort');

            // Gestion de la direction
            if (currentSortColumn === column) {
                currentSortDirection = currentSortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                currentSortColumn = column;
                currentSortDirection = 'asc';
            }

            // Mise à jour des icônes FontAwesome
            sortHeaders.forEach(h => {
                const icon = h.querySelector('.sort-icon');
                icon.className = 'fa-solid fa-sort sort-icon';
                icon.style.opacity = '0.5';
            });
            const currentIcon = this.querySelector('.sort-icon');
            currentIcon.className = currentSortDirection === 'asc' ? 'fa-solid fa-sort-up sort-icon' : 'fa-solid fa-sort-down sort-icon';
            currentIcon.style.opacity = '1';

            // Tri du tableau des lignes global (toutes les lignes)
            rows.sort((a, b) => {
                let valA = getColumnValue(a, column);
                let valB = getColumnValue(b, column);

                // Comparaison numérique vs alphanumérique
                const numA = parseFloat(valA);
                const numB = parseFloat(valB);
                if (!isNaN(numA) && !isNaN(numB) && isFinite(valA) && isFinite(valB)) {
                    valA = numA;
                    valB = numB;
                } else {
                    valA = valA.toString().toLowerCase();
                    valB = valB.toString().toLowerCase();
                }

                if (valA < valB) return currentSortDirection === 'asc' ? -1 : 1;
                if (valA > valB) return currentSortDirection === 'asc' ? 1 : -1;
                return 0;
            });

            // Ré-insérer les lignes dans le DOM dans le nouvel ordre
            rows.forEach(row => tbody.appendChild(row));

            // Ré-appliquer le filtre et la pagination sur les lignes triées
            applyFilters();
        });
    });

    function getColumnValue(row, column) {
        switch(column) {
            case 'sf': return row.querySelector('.col-sf').getAttribute('data-value');
            case 'subsf': return row.querySelector('.col-subsf').getAttribute('data-value');
            case 'name': return row.querySelector('.col-name').textContent.trim();
            case 'gcp': return row.querySelector('.col-gcp').getAttribute('data-value');
            default: return '';
        }
    }


    function applyFilters() {
        const valSf = filterSf.value.toLowerCase();
        const valSubsf = filterSubsf.value.toLowerCase();
        const valName = filterProjectName.value.toLowerCase();
        const valGcp = filterGcp.value.toLowerCase();

        filteredRows = [];

        rows.forEach(row => {
            row.style.display = 'none';

            const sf = row.querySelector('.col-sf').getAttribute('data-value').toLowerCase();
            const subsf = row.querySelector('.col-subsf').getAttribute('data-value').toLowerCase();
            const name = row.querySelector('.col-name').textContent.toLowerCase();
            const gcp = row.querySelector('.col-gcp').getAttribute('data-value').toLowerCase();

            const matchSf = (valSf === 'all' || sf === valSf);
            const matchSubsf = (valSubsf === 'all' || subsf === valSubsf);
            const matchName = (valName === '' || name.includes(valName));
            const matchGcp = (valGcp === 'all' || gcp === valGcp);

            if (matchSf && matchSubsf && matchName && matchGcp) {
                filteredRows.push(row);
            }
        });

        filteredRows.forEach((row, index) => {
            row.querySelector('.col-index').textContent = index + 1;
        });

        currentPage = 1;
        updatePagination();

        // Décoche la case principale si on change les filtres
        checkAll.checked = false;
    }

    function updatePagination() {
        const totalRows = filteredRows.length;
        const totalPages = Math.ceil(totalRows / rowsPerPage);

        if (currentPage < 1) currentPage = 1;
        if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;

        const startIndex = (currentPage - 1) * rowsPerPage;
        const endIndex = startIndex + rowsPerPage;

        filteredRows.forEach(row => row.style.display = 'none');
        displayedRows = filteredRows.slice(startIndex, endIndex);
        displayedRows.forEach(row => row.style.display = '');

        const endDisplayIndex = Math.min(endIndex, totalRows);
        const startDisplayIndex = totalRows === 0 ? 0 : startIndex + 1;
        paginationInfo.textContent = `Affichage de ${startDisplayIndex} à ${endDisplayIndex} sur ${totalRows}`;

        paginationContainer.innerHTML = '';
        if (totalPages <= 1) return;

        paginationContainer.insertAdjacentHTML('beforeend',
            `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" data-page="${currentPage - 1}">&laquo;</a>
            </li>`
        );

        for (let i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
                paginationContainer.insertAdjacentHTML('beforeend',
                    `<li class="page-item ${currentPage === i ? 'active' : ''}">
                        <a class="page-link" href="#" data-page="${i}">${i}</a>
                    </li>`
                );
            } else if (i === currentPage - 3 || i === currentPage + 3) {
                paginationContainer.insertAdjacentHTML('beforeend',
                    `<li class="page-item disabled"><a class="page-link" href="#">...</a></li>`
                );
            }
        }

        paginationContainer.insertAdjacentHTML('beforeend',
            `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" data-page="${currentPage + 1}">&raquo;</a>
            </li>`
        );
    }

    paginationContainer.addEventListener('click', function(e) {
        if (e.target.tagName === 'A') {
            e.preventDefault();
            const page = parseInt(e.target.getAttribute('data-page'));
            if (!isNaN(page)) {
                currentPage = page;
                updatePagination();
            }
        }
    });

    rowsPerPageSelect.addEventListener('change', function() {
        rowsPerPage = parseInt(this.value);
        currentPage = 1;
        updatePagination();
    });

    const inputs = document.querySelectorAll('.filter-input');
    inputs.forEach(input => {
        if (input.tagName === 'SELECT') {
            input.addEventListener('change', applyFilters);
        } else {
            input.addEventListener('input', applyFilters);
        }
    });

    // Logique de sélection globale
    checkAll.addEventListener('change', function(e) {
        const isChecked = e.target.checked;
        // On coche/décoche uniquement les lignes qui correspondent aux filtres actuels
        filteredRows.forEach(row => {
            row.querySelector('.row-checkbox').checked = isChecked;
        });
    });

    applyFilters();
});


function checkSingleRow(btn) {
    const row = btn.closest('.project-row');
    checkHealth('single', row);
}

// --- LOGIQUE DE MONITORING ---
let abortController = null;

async function checkHealth(mode, specificRow = null) {
    const btnCheckSelected = document.getElementById('btn-check-selected');
    const btnStop = document.getElementById('btn-stop-health');
    const singleButtons = document.querySelectorAll('.btn-check-single');

    let targetRows = [];
    if (mode === 'single') {
        targetRows = [specificRow];
    } else if (mode === 'selected') {
        targetRows = Array.from(document.querySelectorAll('.row-checkbox:checked')).map(cb => cb.closest('.project-row'));
    }

    if (targetRows.length === 0 && mode === 'selected') {
        alert("Aucune ligne cochée.");
        return;
    }

    btnCheckSelected.classList.add('d-none');
    btnStop.classList.remove('d-none');
    singleButtons.forEach(btn => btn.disabled = true);

    abortController = new AbortController();
    const signal = abortController.signal;
    const environments = ['dev', 'rec', 'pp', 'prod'];

    targetRows.forEach(row => {
        environments.forEach(env => {
            const cell = row.querySelector(`.col-${env}`);
            if(cell) {
                const urlHealthCheck = cell.getAttribute('data-url-health');

                // Ne met en chargement que si on a une URL de health check
                if (urlHealthCheck && urlHealthCheck !== '') {
                    const badge = cell.querySelector('.health-badge');
                    badge.className = 'health-badge badge badge-warning';
                    badge.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
                }
            }
        });
    });

    try {
        // Traitement des lignes
        for (const row of targetRows) {
            if (signal.aborted) break;

            const projectName = row.getAttribute('data-project-name');
            if (!projectName) {
                updateRowBadgesError(row, environments);
                continue;
            }

            // On lance les requêtes d'environnement pour ce projet via notre backend
            await Promise.all(
                environments.map(env => checkEnvironment(row, projectName, env, signal))
            );
        }
    } catch (error) {
        if (error.name !== 'AbortError') console.error("Erreur inattendue:", error);
    } finally {
        btnCheckSelected.classList.remove('d-none');
        btnStop.classList.add('d-none');
        singleButtons.forEach(btn => btn.disabled = false);

        // S'il y a eu annulation, on remet les badges "En attente" sur ceux qui tournaient encore
        if (signal.aborted) {
            resetPendingBadges(targetRows, environments);
        }
        abortController = null;
    }
}

function stopHealthCheck() {
    if (abortController) {
        abortController.abort(); // Cela déclenche l'exception AbortError dans les fetch en cours
    }
}

async function checkEnvironment(row, projectName, env, signal) {
    const cell = row.querySelector(`.col-${env}`);
    if(!cell) return;

    const urlHealthCheck = cell.getAttribute('data-url-health');
    const badge = cell.querySelector('.health-badge');

    if (!urlHealthCheck || urlHealthCheck === '') {
        updateBadge(badge, 'N/A', 'secondary', '#');
        return;
    }

    try {
        const actionUrl = `?action=getMonitoringData&project=${encodeURIComponent(projectName)}&env=${encodeURIComponent(env)}`;
        const response = await fetch(actionUrl, { signal });
        const data = await response.json();

        if (data.success) {
            // Mise à jour du statut Health
            if (data.health.status === 'UP') {
                updateBadge(badge, '<i class="fa-solid fa-check"></i>', 'success', urlHealthCheck);
            } else {
                updateBadge(badge, '<i class="fa-regular fa-thumbs-down"></i>', 'danger', urlHealthCheck);
            }
        } else {
            updateBadge(badge, 'ERR', 'danger', urlHealthCheck);
        }

    } catch (error) {
        if (error.name === 'AbortError') {
            throw error;
        } else {
            updateBadge(badge, 'ERR', 'danger', urlHealthCheck);
        }
    }
}

function updateBadge(badge, text, type, url) {
    badge.className = `health-badge badge badge-${type}`;
    badge.innerHTML = `<a href="${url}" target="_blank" class="text-white text-decoration-none" title="${url}">${text}</a>`;
}

function updateRowBadgesError(row, environments) {
    environments.forEach(env => {
        const cell = row.querySelector(`.col-${env}`);
        if(cell){
            const urlHealthCheck = cell.getAttribute('data-url-health');
            const badge = cell.querySelector('.health-badge');
            updateBadge(badge, 'N/A', 'secondary', urlHealthCheck || '#');
        }
    });
}

function resetPendingBadges(rows, environments) {
    rows.forEach(row => {
        environments.forEach(env => {
            const cell = row.querySelector(`.col-${env}`);
            if(cell) {
                const badge = cell.querySelector('.health-badge');
                if (badge.innerHTML.includes('spinner-border')) {
                    badge.className = 'health-badge badge badge-secondary';
                    badge.innerHTML = '<i class="fa-solid fa-ban"></i>';
                }
            }
        });
    });
}
</script>
{% endblock body %}
