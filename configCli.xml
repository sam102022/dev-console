<?xml version="1.0" encoding="UTF-8"?>
<configuration xmlns="http://logging.apache.org/log4php/">

	<appender name="myConsoleAppender" class="LoggerAppenderConsole" />
	<appender name="myAppenderFile" class="LoggerAppenderFile">
		<layout class="LoggerLayoutPattern">
			<param name="conversionPattern"
				value="%date [%level] [%logger::%method] line %line %message%newline %exception" />
		</layout>
		<param name="file" value="var/logs/logCli.log" />
	</appender>

	<logger name="index">
		<appender_ref ref="myAppenderFile" />
	</logger>

	<root>
		<level value="DEBUG" />
		<appender_ref ref="myAppenderFile" />
	</root>
</configuration>