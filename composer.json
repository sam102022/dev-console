{
    "name": "sam102022/dev-console",
    "description": "Application pour gérer les projets GitLab et le monitoring de santé des APIs",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mysqli": "*",
        "ext-simplexml": "*",
        "symfony/cache": "^6.4",
        "predis/predis": "^3.0",
        "symfony/cache-contracts": "^3.5",
        "symfony/service-contracts": "^3.5",
        "monolog/monolog": "^3.8",
        "twig/twig": "^3.24",
        "guzzlehttp/guzzle": "^7.10",
        "symfony/twig-bundle": "^8.0",
        "twig/extra-bundle": "^3.24",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "mikey179/vfsstream": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\tests\\": "tests"
        }
    },
    "scripts": {
        "test": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/phpunit"
        ],
        "test:unit": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/phpunit -c tests/phpunit.xml --testsuite \"Unit Tests\""
        ],
        "test:integration": [
            "Composer\\Config::disableProcessTimeout",
            "@set-env-test",
            "vendor/bin/phpunit -c tests/phpunit-it.xml --testsuite \"Integration Tests\""
        ],
        "set-env-test": [
            "php -r \"putenv('APP_ENV=test');\""
        ],
        "php-cs-fixer": [
            "vendor/bin/php-cs-fixer fix --using-cache=no"
        ]
    }
}
